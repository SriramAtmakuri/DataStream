# Copy this file to .env and fill in values for local development (outside Docker).
# When running inside Docker Compose, these are set automatically via the compose file.

KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC_ORDERS=orders
KAFKA_TOPIC_DLQ=orders-dlq
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=ecommerce
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
ORDERS_PER_SECOND=5
GIN_MODE=debug
